# MuleShield AI Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite for development (default)
DATABASE_URL=sqlite:///./muleshield.db
# PostgreSQL for production (recommended)
# DATABASE_URL=postgresql://username:password@localhost:5432/muleshield_prod

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================
# Redis connection string (falls back to in-memory cache if unavailable)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
# Directory for trained model artifacts (scalers, models, imputers)
MODEL_ARTIFACTS_DIR=./artifacts

# Path to training dataset (9,082 rows × 3,924 anonymized features)
DATASET_PATH=./data/DataSet.csv

# MLflow tracking server URI (optional, for experiment tracking)
MLFLOW_TRACKING_URI=http://localhost:5000

# ============================================================================
# ENSEMBLE MODEL WEIGHTS
# ============================================================================
# Weights must sum to 1.00 for proper ensemble averaging
XGBOOST_WEIGHT=0.30
LIGHTGBM_WEIGHT=0.25
CATBOOST_WEIGHT=0.15
ISOLATION_FOREST_WEIGHT=0.15
AUTOENCODER_WEIGHT=0.10
GNN_WEIGHT=0.05

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================
# Score result cache TTL in seconds (Redis/in-memory)
SCORE_CACHE_TTL=60

# SQLAlchemy connection pool size
DB_POOL_SIZE=10

# Maximum overflow connections beyond pool size
DB_MAX_OVERFLOW=20

# Number of Uvicorn worker processes (adjust based on CPU cores)
API_WORKERS=4

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Application secret key for session management and encryption (CHANGE IN PRODUCTION!)
SECRET_KEY=changeme-use-strong-secret-in-production

# Bearer token for /api/v1/regulator/* endpoints (CHANGE IN PRODUCTION!)
REGULATOR_TOKEN=regulator-secret-token

# Allowed CORS origins (comma-separated, add production URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT signing key for analyst authentication (future feature)
# JWT_SECRET_KEY=your-secret-key-here

# Neo4j database authentication (username/password)
NEO4J_AUTH=neo4j/muleshield123

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Global kill switch for automated freeze actions (True to disable all auto-freezes)
KILL_SWITCH_ACTIVE=False

# Enable/disable automatic freeze for CRITICAL risk band accounts
AUTO_FREEZE_ENABLED=True

# Enable/disable automatic goAML STR draft generation
STR_GENERATION_ENABLED=True

# Enable debug logging and FastAPI auto-reload
DEBUG=False

# ============================================================================
# MONITORING SETTINGS
# ============================================================================
# Expose /metrics endpoint for Prometheus scraping
PROMETHEUS_ENABLED=True

# Grafana admin password (CHANGE IN PRODUCTION!)
GRAFANA_ADMIN_PASSWORD=admin

# Audit log retention period (5 years = 1825 days, regulatory requirement)
AUDIT_RETENTION_DAYS=1825

# ============================================================================
# RISK BAND THRESHOLDS (optional overrides)
# ============================================================================
# Default: MINIMAL [0-199], LOW [200-399], MEDIUM [400-599], HIGH [600-799], CRITICAL [800-1000]
# RISK_BAND_MINIMAL_MAX=199
# RISK_BAND_LOW_MAX=399
# RISK_BAND_MEDIUM_MAX=599
# RISK_BAND_HIGH_MAX=799

# ============================================================================
# DETECTION PATTERN THRESHOLDS (optional)
# ============================================================================
# Minimum confidence score for pattern classification (0.0 - 1.0)
PATTERN_CONFIDENCE_THRESHOLD=0.20

# ============================================================================
# SHAP EXPLAINABILITY SETTINGS
# ============================================================================
# Number of top SHAP features to return in API response
SHAP_TOP_N_FEATURES=10

# Number of features to include in NLP narrative
NARRATIVE_TOP_N_FEATURES=3

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# API base URL for frontend (Vite build argument)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production:
# 1. ✅ Change SECRET_KEY to a secure random value
# 2. ✅ Change REGULATOR_TOKEN to a secure random value
# 3. ✅ Use PostgreSQL for DATABASE_URL (not SQLite)
# 4. ✅ Update CORS_ORIGINS with production frontend URL
# 5. ✅ Set DEBUG=False
# 6. ✅ Configure GRAFANA_ADMIN_PASSWORD
# 7. ✅ Change NEO4J_AUTH to secure credentials
# 8. ✅ Increase API_WORKERS based on CPU cores
# 9. ✅ Enable SSL/TLS for Redis and PostgreSQL connections
# 10. ✅ Configure JWT_SECRET_KEY for authentication
# 11. ✅ Review and adjust ensemble weights if needed
# 12. ✅ Set appropriate SCORE_CACHE_TTL for your use case
# 13. ✅ Update VITE_API_BASE_URL with production API endpoint
